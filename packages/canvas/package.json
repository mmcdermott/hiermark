{
  "name": "@ham/canvas",
  "version": "0.1.0",
  "description": "A 2D canvas of editable HAM surfaces connected by block-anchored branch edges.",
  "license": "MIT",
  "author": {
    "name": "Matthew McDermott",
    "email": "mattmcdermott8@gmail.com",
    "url": "https://github.com/mmcdermott"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmcdermott/ham.git",
    "directory": "packages/canvas"
  },
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@dnd-kit/core": "^6",
    "@dnd-kit/sortable": "^10",
    "@dnd-kit/utilities": "^3"
  },
  "peerDependencies": {
    "@ham/editor": "workspace:^",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@ham/editor": "workspace:^",
    "@testing-library/dom": "^10",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
