{
  "name": "@ham/editor",
  "version": "0.2.0",
  "description": "One collaborative, block-centric markdown surface for HAM (Tiptap 3 / ProseMirror).",
  "license": "MIT",
  "author": {
    "name": "Matthew McDermott",
    "email": "mattmcdermott8@gmail.com",
    "url": "https://github.com/mmcdermott"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmcdermott/ham.git",
    "directory": "packages/editor"
  },
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./markdown": {
      "import": {
        "types": "./dist/markdown.d.ts",
        "default": "./dist/markdown.js"
      },
      "require": {
        "types": "./dist/markdown.d.cts",
        "default": "./dist/markdown.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27",
    "@hocuspocus/provider": "^4",
    "@tiptap/core": "^3",
    "@tiptap/extension-code-block-lowlight": "^3.26.0",
    "@tiptap/extension-collaboration": "^3",
    "@tiptap/extension-collaboration-caret": "^3",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-mathematics": "^3",
    "@tiptap/extension-placeholder": "^3",
    "@tiptap/extension-table": "^3",
    "@tiptap/extension-task-item": "^3",
    "@tiptap/extension-task-list": "^3",
    "@tiptap/markdown": "^3",
    "@tiptap/pm": "^3",
    "@tiptap/react": "^3",
    "@tiptap/starter-kit": "^3",
    "@tiptap/suggestion": "^3",
    "katex": "^0.16.4",
    "lowlight": "^3.3.0",
    "nanoid": "^5",
    "y-prosemirror": "^1.3",
    "yjs": "^13"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19",
    "react-dom": "^18.3.0 || ^19"
  },
  "devDependencies": {
    "@testing-library/dom": "^10",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/katex": "^0.16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4"
  }
}
