{
  "name": "ham-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Hierarchical, Annotatable Markdown (HAM): a 2D canvas of linked, editable markdown surfaces with rich annotations and block-anchored branching.",
  "license": "MIT",
  "author": {
    "name": "Matthew McDermott",
    "email": "mattmcdermott8@gmail.com",
    "url": "https://github.com/mmcdermott"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mmcdermott/ham.git"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm -F @ham/docs dev",
    "test": "pnpm -r --no-bail test",
    "test:run": "pnpm -r --no-bail test:run",
    "typecheck": "pnpm -r --no-bail typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:api": "typedoc",
    "docs:build": "pnpm build && pnpm docs:api && pnpm -F @ham/docs build",
    "lint:pkg": "pnpm build && pnpm -r --filter \"./packages/*\" exec publint",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "clean": "pnpm -r exec rm -rf dist dist-types coverage .vite"
  },
  "devDependencies": {
    "@changesets/cli": "^2",
    "@eslint/js": "^9",
    "@types/node": "^22",
    "axe-core": "^4.12.1",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^16",
    "prettier": "^3",
    "publint": "^0.3",
    "typedoc": "^0.28.19",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest-axe": "^0.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
